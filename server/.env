# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/luxe_commerce

# Auth
JWT_ACCESS_SECRET=replace_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=replace_me_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cloudinary (leave blank to use local disk fallback in dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (test mode)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Mail (e.g. Mailtrap / SendGrid SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Luxe <no-reply@luxe.dev>"

# Seed admin
SEED_ADMIN_EMAIL=admin@luxe.dev
SEED_ADMIN_PASSWORD=Admin@123
